# Normalizacja końców linii — domyślnie LF w repo (deterministyczne diffy między OS)
* text=auto eol=lf

# Źródła i konfiguracja — wymuszony LF
*.cs        text eol=lf
*.csproj    text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.json      text eol=lf
*.config    text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sln       text eol=lf
*.slnx      text eol=lf
*.editorconfig text eol=lf
*.sh        text eol=lf

# Skrypty Windows — wymagają CRLF
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Pliki binarne — bez normalizacji ani diffowania
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.snk       binary
*.pfx       binary
*.pem       binary
