root = true

# Zadanie 0.2 (Feature 0 / szkielet solution): severities analizatorów Roslyn.
# Rodzina reguł bezpieczeństwa (CA2xxx-sec / CA3xxx / CA5xxx) oraz forward CancellationToken
# podniesione do błędu kompilacji — bramka SAST (TESTING-SPEC §8 poz. 4) działa od pierwszego commita.

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.cs]
indent_size = 4

# Rodzina reguł bezpieczeństwa Roslyn NetAnalyzers jako błąd (obejmuje CA3xxx/CA5xxx).
dotnet_analyzer_diagnostic.category-Security.severity = error

# CA2016 — Forward the CancellationToken parameter to methods (CONSTITUTION §1.3 / ADR-013).
dotnet_diagnostic.CA2016.severity = error

[*.{csproj,props,targets,slnx}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2
