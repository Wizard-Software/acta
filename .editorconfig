root = true

# Roslyn analyzer severities. The security rule family (CA2xxx-sec / CA3xxx / CA5xxx) and
# forward-CancellationToken are raised to build errors — the SAST gate is active from the
# first commit.

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.cs]
indent_size = 4

# Roslyn NetAnalyzers security rule family as errors (covers CA3xxx/CA5xxx).
dotnet_analyzer_diagnostic.category-Security.severity = error

# CA2016 — Forward the CancellationToken parameter to methods.
dotnet_diagnostic.CA2016.severity = error

[*.{csproj,props,targets,slnx}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2
