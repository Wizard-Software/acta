<?xml version="1.0" encoding="utf-8"?>
<!-- Łańcuch dostaw (Feature 0 / 0.1, R3-B4): jedno przypięte, zaufane źródło pakietów
     od pierwszego commita. <clear /> usuwa źródła odziedziczone z konfiguracji maszyny. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
